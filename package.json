{
	"name": "yauth",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "bun run --filter '*' build",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "bun run --filter '*' typecheck",
		"test": "bun run --filter '*' test",
		"validate": "bun run lint:fix && bun run typecheck && bun run build",
		"validate:ci": "bun run lint && bun run typecheck && bun run build",
		"clean": "rm -rf node_modules packages/*/node_modules packages/*/dist"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/bun": "^1.3.10",
		"typescript": "^5.9.3"
	},
	"engines": {
		"node": ">=20"
	}
}
