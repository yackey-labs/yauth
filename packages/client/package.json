{
	"name": "@yauth/client",
	"version": "0.1.5",
	"type": "module",
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "src/index.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
