{
	"name": "@yackey-labs/yauth-ui-vue",
	"version": "0.6.1",
	"repository": {
		"type": "git",
		"url": "https://github.com/yackey-labs/yauth"
	},
	"type": "module",
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "src/index.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./composables": {
			"import": "./dist/composables.js",
			"types": "./src/composables/index.ts",
			"default": "./src/composables/index.ts"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "vite build",
		"typecheck": "vue-tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"@simplewebauthn/browser": "^13.0.0",
		"@yackey-labs/yauth-client": "0.6.1",
		"@yackey-labs/yauth-shared": "0.6.1",
		"vue": "^3.5.0"
	},
	"devDependencies": {
		"@vitejs/plugin-vue": "^5.2.0",
		"@vue/test-utils": "^2.4.6",
		"happy-dom": "^20.8.9",
		"typescript": "^5.7.2",
		"vite": "^7.3.1",
		"vitest": "^3.1.4",
		"vue-tsc": "^2.2.8"
	},
	"peerDependencies": {
		"vue": "^3.5.0"
	},
	"sideEffects": false
}
